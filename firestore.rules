rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =====================================================
       🔐 HELPER FUNCTIONS (GLOBAL)
    ====================================================== */

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /* =====================================================
       🔐 INTERNAL PORTAL COLLECTIONS
       (Login required)
    ====================================================== */

    // Teachers Directory
    match /teachers/{docId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isAuth() && request.auth.token.email.lower() == resource.data.email.lower());
    }

    // Users (Auth profiles & roles)
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Classes
    match /classes/{classId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin() ||
        (isAuth() && resource.data.teacherUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Class Routines
    match /class_routines/{routineId} {
      allow read, write: if isAuth();
    }

    // Class Schedules
    match /class_schedules/{scheduleId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Resources Library
    match /resources/{resourceId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Batch Info
    match /batch_info/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Batches (Dynamic Batch Mapping)
    match /batches/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }


    // Notices
    match /notices/{noticeId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Policies
    match /policies/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Meeting Minutes
    match /meeting_minutes/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Student Profile Updates
    match /student_profile_updates/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin() || isAuth(); // Students create, admins review/delete
    }

    // Public Batch Students list for registration
    match /public_batch_students/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Exam Results
    match /exam_results/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Student Notices - any authenticated teacher/admin can write, students & all auth users can read
    match /student_notices/{docId} {
      allow read: if true; // Students read before login; also shown in dashboard
      allow write: if isAuth(); // Teachers and admins can post
    }

    // Student Contact Messages - students create, admins read/manage
    match /contact_messages/{docId} {
      allow create: if isAuth(); // Any logged-in student can submit
      allow read, update, delete: if isAdmin();
    }

    // Module Resources - teachers upload for their own module, admin manages all
    match /module_resources/{docId} {
      allow read: if isAuth(); // Students and teachers all can read
      allow create: if isAuth(); // Any logged-in teacher can upload
      allow update, delete: if isAuth() && (
        resource.data.teacherUid == request.auth.uid || isAdmin()
      );
    }

    // Homework Submissions — Students create, all auth read, admin/system deletes
    match /homework_submissions/{docId} {
      allow create: if isAuth();
      allow read: if isAuth();
      allow update: if false; // Homework cannot be edited once submitted
      allow delete: if isAuth(); // Allow authenticated users (admin cleanup runs client-side)
    }

    /* =====================================================
       📩 FEEDBACK SYSTEM
       (Public submit + Admin approval)
    ====================================================== */

    match /feedback/{feedbackId} {
      // Public can submit feedback
      allow create: if true;

      // Admin can read everything
      // Public can read only APPROVED feedback
      allow read: if isAdmin() || resource.data.status == 'APPROVED';

      // Only admin can approve / delete
      allow update, delete: if isAdmin();
    }

    /* =====================================================
       🌐 PUBLIC WEBSITE COLLECTIONS
       (No login required for read)
    ====================================================== */

    // Blog Comments (Public read, write, update for likes/replies)
    match /blogComments/{commentId} {
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    // Blog Posts
    match /blog_posts/{postId} {
      allow read: if resource.data.status == "published";
      allow create, update, delete: if isAdmin();
    }

    // Posts (Legacy blog collection)
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Instructors (Public view)
    match /instructors/{docId} {
      allow read: if resource.data.active == true;
      allow create, update, delete: if isAdmin();
    }

    // Course Modules
    match /course_modules/{docId} {
      allow read: if resource.data.active == true || isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Success Stories: Video Testimonials
    match /successVideos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Success Stories: Written Reviews
    match /successReviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    /* =====================================================
       📩 CONTACT FORM (PUBLIC)
    ====================================================== */

    match /contact_inquiries/{docId} {
      // Public can submit contact form
      allow create: if true;

      // Only admin can read & manage
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    /* =====================================================
       🛠️ SYSTEM / ACTIVITY LOGS
    ====================================================== */

    match /activity_logs/{logId} {
      allow create: if isAuth();
      allow read: if isAdmin();
    }

    /* =====================================================
       🚫 DEFAULT DENY (SECURITY NET)
    ====================================================== */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
